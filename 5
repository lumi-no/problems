#include <iostream>
#include <functional>

using namespace std;

template<typename T>
class Option
{
private:
    bool hasValue;
    T value;

public:
    Option()
    {
        hasValue = false;
        value = T();
    }

    Option(T value)
    {
        hasValue = true;
        this->value = value;
    }

    bool isSome()
    {
        return hasValue;
    }

    T getValue()
    {
        return value;
    }

    Option<T> map(function<T(T)> func)
    {
        if (hasValue)
        {
            return Option<T>(func(value));
        }

        return Option<T>();
    }
};

int main()
{
    Option<int> some(5);

    Option<int> result = some.map(
        [](int x)
        {
            return x * 2;
        });

    if (result.isSome())
    {
        cout << "Some(" << result.getValue() << ")" << endl;
    }
    else
    {
        cout << "Nothing()" << endl;
    }

    Option<int> nothing;

    Option<int> result2 = nothing.map(
        [](int x)
        {
            return x * 2;
        });

    if (result2.isSome())
    {
        cout << "Some(" << result2.getValue() << ")" << endl;
    }
    else
    {
        cout << "Nothing()" << endl;
    }

    return 0;
}
